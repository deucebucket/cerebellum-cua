# cerebellum-cua environment template (KEYS ONLY — no real values).
#
# Copy this file to `.env` and fill in values:
#     cp .env.example .env
#
# `.env` is gitignored and MUST NEVER be committed. Only this `.env.example`
# template (keys, no secrets) belongs in version control.
#
# Resolution precedence: a real environment variable always wins over the value
# in `.env`. CLI flags (--secret / --db-dsn) win over both.

# HS256 secret used to sign/verify lazy-load JWT tokens. Required (from a flag,
# this file, or the environment) before the engine will start. Use a long random
# string, e.g. `openssl rand -hex 32`.
CEREBELLUM_SECRET=

# Storage DSN. Either a SQLite path (e.g. ./state.db or sqlite:///abs/path.db)
# or a PostgreSQL URL (postgresql://user:pass@host:5432/matrixui). Required.
CEREBELLUM_DB_DSN=

# OPTIONAL and SENSITIVE. Password used only to answer an elevation prompt
# (sudo / polkit on Linux, UAC on Windows) when a tutorial deliberately drives
# such a dialog. Leave BLANK to disable elevation handling entirely. Never
# commit a real value.
CEREBELLUM_ELEVATION_PASSWORD=
